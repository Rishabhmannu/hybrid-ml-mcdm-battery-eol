# =====================================================================
# .gitignore — Hybrid ML-MCDM Framework for EV Battery EoL Routing
# =====================================================================

# ---------- Datasets (all data, raw + processed + regulatory) ----------
# Leading slash anchors to project root so `src/data/` (Python source)
# is NOT excluded by these rules.
#
# Default: everything under /data/ is ignored. Two small files used by the
# live demo at runtime are explicitly opted back in via the descending-pattern
# trick (ignore contents, allow specific subdirs, ignore THEIR contents,
# allow specific files). Both are <50 KB.
/data/*
!/data/processed/
/data/processed/*
!/data/processed/dpp/
!/data/processed/mcdm_weights/
/data/processed/dpp/*
!/data/processed/dpp/unified_dpp_schema.json
/data/processed/mcdm_weights/*
!/data/processed/mcdm_weights/fuzzy_bwm_input.csv

/manually-downloaded-data/
/research-papers/
/freshly-downloaded-papers/

# ---------- Secrets / env ----------
.env
*.env
.venv/
venv/

# ---------- All Markdown documents (shared via Drive, not git) ----------
*.md
# But always ship the public-facing READMEs.
!README.md
!frontend/README.md

# ---------- Trained model artifacts ----------
# Hosted on the Hugging Face Hub (cmpunkmannu/hybrid-ml-mcdm-battery-eol);
# fetched at runtime via huggingface_hub.hf_hub_download. Local /models/
# is the training-side output directory only.
/models/

# ---------- Internal sample / validation artefacts ----------
# Sample PDFs, screenshots, downloaded DPP JSONs Rishabh uses to vet the
# demo before push. Local-only — never push.
/sample-data-testing/

# ---------- Institute-owned and internal scratch files ----------
# project-guidelines.pdf is the IIIT-A assignment brief (institute-copyrighted).
# The WIP PDF and the .docx builder are internal-only academic submissions.
# All three stay on the local disk but are excluded from the public repo.
/project-guidelines.pdf
/build_proposal_docx.py
/Digital Economics Semester 8 - Work in Progress.pdf

# ---------- Run-time outputs ----------
# figures + DPP JSONs are regenerable; keep results/tables/ in-repo for
# reproducibility evidence (small JSON / CSV metric files).
/results/figures/
/results/dpp_output/

# ---------- Claude Code internal state (agent worktrees, settings) ----------
.claude/

# ---------- Python ----------
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
*.egg
*.so

# ---------- Jupyter ----------
.ipynb_checkpoints/

# ---------- OS ----------
.DS_Store
Thumbs.db
*.swp
*.swo

# ---------- IDE ----------
.vscode/
.idea/
.history/

# ---------- Logs / scratch ----------
*.log
nohup.out
